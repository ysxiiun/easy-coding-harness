{
  "name": "easy-coding-harness",
  "version": "0.7.0",
  "description": "CLI scaffold for installing Easy Coding harness files into agent-native directories.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ysxiiun/easy-coding-harness.git"
  },
  "homepage": "https://github.com/ysxiiun/easy-coding-harness#readme",
  "bugs": {
    "url": "https://github.com/ysxiiun/easy-coding-harness/issues"
  },
  "type": "module",
  "bin": {
    "easy-coding": "./dist/cli.js"
  },
  "files": [
    "CHANGELOG.md",
    "dist/",
    "templates/"
  ],
  "scripts": {
    "build": "tsup && npm run copy-templates",
    "copy-templates": "node scripts/copy-templates.mjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run test && npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "harness",
    "cli",
    "claude",
    "codex",
    "qoder"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.1",
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "figlet": "^1.9.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/figlet": "^1.7.0",
    "@types/node": "^20.17.12",
    "@vitest/coverage-v8": "^2.1.8",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
